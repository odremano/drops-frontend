---
const message = 'EDICIÓN LIMITADA · ORDEMA DROP 001 · SIN REPOSICIÓN · CUANDO SE VA, NO VUELVE · SOLO UNIDADES DISPONIBLES · CALIDAD PREMIUM ·';
const repeated = message.repeat(6);
---

<div class="bg-stone-900 text-stone-100 overflow-hidden py-3 sticky top-0 z-50">
  <div class="ticker-track flex whitespace-nowrap will-change-transform">
    <span class="text-[10px] font-semibold tracking-[0.25em] uppercase pr-0">
      {repeated}
    </span>
    <span class="text-[10px] font-semibold tracking-[0.25em] uppercase" aria-hidden="true">
      {repeated}
    </span>
  </div>
</div>
